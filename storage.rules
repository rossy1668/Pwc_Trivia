rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Permitir lectura pública para todos los archivos en la carpeta denuncias
    match /denuncias/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Para otras carpetas, requerir autenticación
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}