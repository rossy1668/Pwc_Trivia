rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Permitir lectura de resultados de trivia para usuarios autenticados
    match /resultados_trivia/{resultadoId} {
      allow read: if request.auth != null;
      allow create: if true;
      allow update, delete: if false;
    }

    match /denuncias/{denunciaId} {
      // Permitir creación de denuncias incluso si el usuario es anónimo
      allow create: if true;
      // No permitir actualizaciones o borrados desde el cliente
      allow update, delete: if false;

      // Permitir lectura para usuarios autenticados (para el dashboard)
      allow read: if request.auth != null;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}